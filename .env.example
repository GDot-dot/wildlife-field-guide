# GEMINI_API_KEY: Required for Gemini AI API calls.
# For GitHub Pages, this is injected at build time from GitHub Actions secrets.
# This is convenient for a low-publicity personal project, but it is not a
# strictly private secret once bundled into frontend JavaScript.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# VITE_AI_PROXY_URL: Optional, recommended for stricter production security.
# Point this to a small backend endpoint that owns GEMINI_API_KEY and accepts
# POST { action: "recognize" | "enrich", ...payload }. Do not expose Gemini keys
# directly in a public static build.
VITE_AI_PROXY_URL="MY_AI_PROXY_URL"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
