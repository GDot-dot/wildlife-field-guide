rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: user_collections
    // Document ID: {userId}_{animalId}
    // Fields:
    //   - userId: string (required) - The ID of the user
    //   - animalId: string (required) - The ID of the animal
    //   - animalName: string (optional) - The name of the animal
    //   - animalImageUrl: string (optional) - The image URL of the animal
    //   - soundUrl: string (optional) - The sound URL of the animal
    //   - characteristics: string (optional) - The characteristics
    //   - diet: string (optional) - The diet
    //   - habitat: string (optional) - The habitat
    //   - description: string (optional) - The observation description
    //   - collectedAt: timestamp (required) - When it was collected
    //   - notes: string (optional, max 500 chars) - User notes
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidCollectionRecord(data) {
      let hasRequired = data.keys().hasAll(['userId', 'animalId', 'collectedAt']);
      let hasOnlyAllowed = data.keys().hasOnly(['userId', 'animalId', 'animalName', 'animalImageUrl', 'soundUrl', 'characteristics', 'diet', 'habitat', 'description', 'collectedAt', 'notes']);
      
      let validUserId = data.userId is string && data.userId.size() > 0 && data.userId.size() < 100;
      let validAnimalId = data.animalId is string && data.animalId.size() > 0 && data.animalId.size() < 100;
      let validTimestamp = data.collectedAt is timestamp;
      
      let validOptionalStrings = (!('notes' in data) || (data.notes is string && data.notes.size() <= 500))
        && (!('animalName' in data) || (data.animalName is string && data.animalName.size() <= 200))
        && (!('animalImageUrl' in data) || (data.animalImageUrl is string && data.animalImageUrl.size() <= 1000))
        && (!('soundUrl' in data) || (data.soundUrl is string && data.soundUrl.size() <= 1000))
        && (!('characteristics' in data) || (data.characteristics is string && data.characteristics.size() <= 1000))
        && (!('diet' in data) || (data.diet is string && data.diet.size() <= 500))
        && (!('habitat' in data) || (data.habitat is string && data.habitat.size() <= 500))
        && (!('description' in data) || (data.description is string && data.description.size() <= 500));

      return hasRequired && hasOnlyAllowed && validUserId && validAnimalId && validTimestamp && validOptionalStrings;
    }

    match /user_collections/{recordId} {
      // Users can only read their own records
      // We also allow list queries where userId == request.auth.uid
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      
      // Users can only create records for themselves
      allow create: if isAuthenticated() 
                    && isValidCollectionRecord(request.resource.data) 
                    && request.resource.data.userId == request.auth.uid
                    && recordId == request.auth.uid + '_' + request.resource.data.animalId;
                    
      // Users can only update their own records (e.g., to add notes)
      allow update: if isAuthenticated() 
                    && resource.data.userId == request.auth.uid
                    && isValidCollectionRecord(request.resource.data)
                    && request.resource.data.userId == resource.data.userId
                    && request.resource.data.animalId == resource.data.animalId
                    && request.resource.data.collectedAt == resource.data.collectedAt; // Immutable fields
                    
      // Users can delete their own records
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
  }
}
